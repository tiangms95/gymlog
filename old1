<script>

(function(){
  try{
    var p=JSON.parse(localStorage.getItem('gym_profile')||'{}');
    if(p.theme) document.body.className='theme-'+p.theme;
    if(p.accent){
      var r=document.documentElement.style;
      r.setProperty('--acc',p.accent);
      r.setProperty('--grad1',p.accent);
      r.setProperty('--grad2',p.accent2||'#C87FE0');
    }
  }catch(e){}
})();
</script>
