<body class="theme-dark">

<div id="splash"><div class="splash-logo">GymLog</div><div class="splash-sub">加载中...</div></div>
<div class="toast" id="toast">✓ 已保存</div>

<!-- ══════════════ SETUP WIZARD ══════════════ -->
<div id="setup-overlay">
  <div class="setup-wrap">
    <div class="setup-logo">GymLog</div>
    <div class="setup-tagline">你的私人训练记录本</div>

    <!-- progress dots -->
    <div class="progress-dots">
      <div class="pdot active" id="pd0"></div>
      <div class="pdot" id="pd1"></div>
      <div class="pdot" id="pd2"></div>
      <div class="pdot" id="pd3"></div>
    </div>

    <!-- STEP 0: profile -->
    <div class="setup-step active" id="step-0">
      <div class="setup-section">
        <div class="setup-label">你的名字</div>
        <input class="setup-input" id="s-name" type="text" placeholder="输入名字" maxlength="20">
      </div>
      <div class="setup-section">
        <div class="setup-label">身高 &amp; 体重</div>
        <div class="setup-row">
          <div style="position:relative">
            <input class="setup-input" id="s-height" type="number" inputmode="decimal" placeholder="身高" min="100" max="230" oninput="calcBMIPreview()">
            <span style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:12px">cm</span>
          </div>
          <div style="position:relative">
            <input class="setup-input" id="s-weight" type="number" inputmode="decimal" placeholder="体重" min="30" max="300" oninput="calcBMIPreview()">
            <span style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:12px">kg</span>
          </div>
        </div>
        <div class="bmi-preview" id="bmi-preview">
          <div class="bmi-preview-row">
            <div>
              <div style="font-size:11px;color:var(--muted);margin-bottom:2px">你的 BMI</div>
              <div style="font-size:24px;font-weight:700" id="bmi-preview-val">—</div>
            </div>
            <div style="text-align:right">
              <div style="font-size:11px;color:var(--muted);margin-bottom:2px">分类</div>
              <div style="font-size:15px;font-weight:600" id="bmi-preview-cat">—</div>
            </div>
          </div>
          <div class="bmi-bar"><div class="bmi-marker" id="bmi-marker" style="left:10%"></div></div>
          <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:9px;color:var(--muted)">
            <span>偏瘦&lt;18.5</span><span>正常 18.5–25</span><span>过重 25–30</span><span>肥胖&gt;30</span>
          </div>
        </div>
      </div>
      <div class="setup-section">
        <div class="setup-label">目标体重（可选）</div>
        <div style="position:relative">
          <input class="setup-input" id="s-goal-weight" type="number" inputmode="decimal" placeholder="例如 70">
          <span style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:12px">kg</span>
        </div>
      </div>
      <button class="btn-primary" onclick="nextStep(1)">继续 →</button>
    </div>

    <!-- STEP 1: goals -->
    <div class="setup-step" id="step-1">
      <div class="setup-section">
        <div class="setup-label">主要目标（可多选）</div>
        <div class="goal-grid">
          <div class="goal-opt" onclick="toggleGoal(this,'fat')" data-goal="fat"><span class="goal-ico">🔥</span>减脂瘦身</div>
          <div class="goal-opt" onclick="toggleGoal(this,'muscle')" data-goal="muscle"><span class="goal-ico">💪</span>增肌塑形</div>
          <div class="goal-opt" onclick="toggleGoal(this,'strength')" data-goal="strength"><span class="goal-ico">⚡</span>增强体力</div>
          <div class="goal-opt" onclick="toggleGoal(this,'health')" data-goal="health"><span class="goal-ico">❤️</span>保持健康</div>
        </div>
      </div>
      <div class="setup-section">
        <div class="setup-label">健身经验</div>
        <select class="setup-select" id="s-level">
          <option value="beginner">新手（几乎没运动过）</option>
          <option value="returning" selected>有基础，停了一段时间</option>
          <option value="intermediate">有一定训练经验</option>
        </select>
      </div>
      <button class="btn-primary" onclick="nextStep(2)">继续 →</button>
      <button class="btn-secondary" onclick="nextStep(0)">← 上一步</button>
    </div>

    <!-- STEP 2: training days -->
    <div class="setup-step" id="step-2">
      <div class="setup-section">
        <div class="setup-label">一周练几天？</div>
        <div class="days-grid">
          <div class="day-opt" onclick="selectDaysPerWeek(this,2)" data-n="2"><span class="day-opt-n">2</span>天 / 周<br><span style="font-size:10px;color:var(--muted)">轻松起步</span></div>
          <div class="day-opt" onclick="selectDaysPerWeek(this,3)" data-n="3"><span class="day-opt-n">3</span>天 / 周<br><span style="font-size:10px;color:var(--muted)">均衡推荐</span></div>
          <div class="day-opt" onclick="selectDaysPerWeek(this,4)" data-n="4"><span class="day-opt-n">4</span>天 / 周<br><span style="font-size:10px;color:var(--muted)">进阶燃脂</span></div>
        </div>
      </div>
      <div class="setup-section" id="weekday-picker" style="display:none">
        <div class="setup-label">选择训练日</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap" id="weekday-grid"></div>
        <div style="margin-top:8px;font-size:12px;color:var(--muted)" id="weekday-hint"></div>
      </div>
      <div id="schedule-preview" style="margin-bottom:16px"></div>
      <button class="btn-primary" onclick="nextStep(3)" id="step2-next" disabled style="opacity:.5">继续 →</button>
      <button class="btn-secondary" onclick="nextStep(1)">← 上一步</button>
    </div>

    <!-- STEP 3: theme -->
    <div class="setup-step" id="step-3">
      <div class="setup-section">
        <div class="setup-label">选择主题风格</div>
        <div class="theme-grid">
          <div class="theme-opt sel" onclick="pickTheme(this,'dark')" style="background:#141420">
            <span>🌑</span><span style="color:#888">深黑</span>
          </div>
          <div class="theme-opt" onclick="pickTheme(this,'midnight')" style="background:#0D1020">
            <span>🌌</span><span style="color:#789">午夜蓝</span>
          </div>
          <div class="theme-opt" onclick="pickTheme(this,'forest')" style="background:#101A12">
            <span>🌲</span><span style="color:#7A9A7A">森林绿</span>
          </div>
          <div class="theme-opt" onclick="pickTheme(this,'warm')" style="background:#201610">
            <span>🔥</span><span style="color:#A08060">暖棕</span>
          </div>
          <div class="theme-opt" onclick="pickTheme(this,'light')" style="background:#F5F2EE">
            <span>☀️</span><span style="color:#666">浅色</span>
          </div>
        </div>
      </div>
      <div class="setup-section">
        <div class="setup-label">强调色</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
