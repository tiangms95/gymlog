const SCHEDULE_TEMPLATES = {
  2: { days:['A','C'], rest:[0,1,0,1,0,1,1] },
  3: { days:['A','B','C'], rest:[0,1,0,0,1,0,1] },
  4: { days:['A','B','C','D'], rest:[0,0,1,0,0,1,1] },
};
const DOW = ['一','二','三','四','五','六','日'];
const DOW_FULL = ['周一','周二','周三','周四','周五','周六','周日'];

let profile = {};
let logs = {};
let currentDay = null;
let setupGoals = [];
let setupDaysPerWeek = 0;
let setupTrainDays = []; 

function todayKey(){ return new Date().toISOString().slice(0,10); }
function todayDOW(){ return (new Date().getDay()+6)%7; } 

function loadData(){
  try{ profile = JSON.parse(localStorage.getItem('gym_profile')||'{}'); }catch(e){ profile={}; }
  try{ logs = JSON.parse(localStorage.getItem('gym_logs')||'{}'); }catch(e){ logs={}; }
}
function saveProfile(){ localStorage.setItem('gym_profile', JSON.stringify(profile)); }
function saveLogs(){
  localStorage.setItem('gym_logs', JSON.stringify(logs));
  showToast();
}
function showToast(){ const t=document.getElementById('toast'); t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),1500); }

function getDayLog(dayId){
  const k=todayKey();
  if(!logs[k]) logs[k]={};
  if(!logs[k][dayId]) logs[k][dayId]={};
  return logs[k][dayId];
}

function calcBMIPreview(){
  const h=parseFloat(document.getElementById('s-height').value);
  const w=parseFloat(document.getElementById('s-weight').value);
  const prev=document.getElementById('bmi-preview');
  if(!h||!w||h<100||w<30){ prev.style.display='none'; return; }
  const bmi=(w/(h/100)**2);
  const bmiStr=bmi.toFixed(1);
  let cat,catColor;
  if(bmi<18.5){cat='偏瘦';catColor='#5F9FF4';}
  else if(bmi<25){cat='正常';catColor='#5FCC7A';}
  else if(bmi<30){cat='过重';catColor='#F4C25F';}
  else{cat='肥胖';catColor='#F4845F';}
  document.getElementById('bmi-preview-val').textContent=bmiStr;
  document.getElementById('bmi-preview-val').style.color=catColor;
  document.getElementById('bmi-preview-cat').textContent=cat;
  document.getElementById('bmi-preview-cat').style.color=catColor;
  
  const pct=Math.min(Math.max((bmi-15)/20*100,2),98);
  document.getElementById('bmi-marker').style.left=pct+'%';
  prev.style.display='block';
}

function toggleGoal(el,key){
  el.classList.toggle('sel');
  if(el.classList.contains('sel')) setupGoals.push(key);
  else setupGoals=setupGoals.filter(g=>g!==key);
}

function selectDaysPerWeek(el,n){
  document.querySelectorAll('.day-opt').forEach(d=>d.classList.remove('sel'));
  el.classList.add('sel');
  setupDaysPerWeek=n;
  buildWeekdayPicker(n);
}

function buildWeekdayPicker(n){
  const picker=document.getElementById('weekday-picker');
  const grid=document.getElementById('weekday-grid');
  const hint=document.getElementById('weekday-hint');
  picker.style.display='block';
  grid.innerHTML='';
  setupTrainDays=[];
  
  const defaults={ 2:[0,3], 3:[0,2,4], 4:[0,1,3,4] };
  const def=defaults[n]||[];
  DOW.forEach((d,i)=>{
    const btn=document.createElement('div');
    btn.style.cssText='width:40px;height:40px;border-radius:10px;border:1px solid var(--border);background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;transition:all .2s;color:var(--muted)';
    btn.textContent='周'+d;
    btn.style.fontSize='11px';
    if(def.includes(i)){
      btn.style.background='var(--acc)20';
      btn.style.borderColor='var(--acc)60';
      btn.style.color='var(--acc)';
      setupTrainDays.push(i);
    }
    btn.onclick=()=>toggleWeekday(btn,i,n);
    grid.appendChild(btn);
  });
  hint.textContent=`已选 ${setupTrainDays.length}/${n} 天`;
  buildSchedulePreview(n);
  document.getElementById('step2-next').disabled=setupTrainDays.length!==n;
  document.getElementById('step2-next').style.opacity=setupTrainDays.length===n?'1':'0.5';
}

function toggleWeekday(btn,idx,n){
  if(setupTrainDays.includes(idx)){
    setupTrainDays=setupTrainDays.filter(d=>d!==idx);
    btn.style.background='var(--bg2)';
    btn.style.borderColor='var(--border)';
    btn.style.color='var(--muted)';
  } else {
    if(setupTrainDays.length>=n){ showToastMsg(`最多选 ${n} 天`); return; }
    setupTrainDays.push(idx);
    btn.style.background='var(--acc)20';
    btn.style.borderColor='var(--acc)60';
    btn.style.color='var(--acc)';
  }
  document.getElementById('weekday-hint').textContent=`已选 ${setupTrainDays.length}/${n} 天`;
  buildSchedulePreview(n);
  const ok=setupTrainDays.length===n;
  document.getElementById('step2-next').disabled=!ok;
  document.getElementById('step2-next').style.opacity=ok?'1':'0.5';
}

function showToastMsg(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>{t.classList.remove('show');t.textContent='✓ 已保存';},1500); }

function buildSchedulePreview(n){
  const sorted=[...setupTrainDays].sort((a,b)=>a-b);
  const tmpl=ALL_DAYS.slice(0,n);
  const prev=document.getElementById('schedule-preview');
  if(sorted.length!==n){ prev.innerHTML=''; return; }
  let html='<div style="background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:14px 16px;margin-bottom:4px">';
  html+='<div style="font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px">你的训练安排</div>';
  html+='<div style="display:flex;gap:6px;flex-wrap:wrap">';
  for(let i=0;i<7;i++){
    const trainIdx=sorted.indexOf(i);
    const isTraining=trainIdx!==-1;
    const day=isTraining?tmpl[trainIdx]:null;
    html+=`<div style="flex:1;min-width:36px;text-align:center;border-radius:8px;padding:8px 4px;background:${isTraining?day.color+'18':'var(--bg3)'};border:1px solid ${isTraining?day.color+'40':'transparent'}">
      <div style="font-size:9px;color:var(--muted);margin-bottom:3px">周${DOW[i]}</div>
      <div style="font-size:11px;font-weight:600;color:${isTraining?day.color:'var(--muted)'}">
        ${isTraining?'Day '+day.id:'休'}
      </div>
    </div>`;
  }
  html+='</div></div>';
  prev.innerHTML=html;
}

function pickTheme(el,name){
  document.querySelectorAll('.theme-opt').forEach(t=>t.classList.remove('sel'));
  el.classList.add('sel');
  document.body.className='theme-'+name;
  if(!profile.theme) profile.theme=name;
  profile.theme=name;
}

function pickAccent(el,c1,c2){
  document.querySelectorAll('[onclick^="pickAccent"]').forEach(e=>e.style.borderColor='transparent');
  el.style.borderColor='var(--text)';
  document.documentElement.style.setProperty('--acc',c1);
  document.documentElement.style.setProperty('--grad1',c1);
  document.documentElement.style.setProperty('--grad2',c2);
  profile.accent=c1; profile.accent2=c2;
}

function nextStep(n){
  if(n===1){
    
    const name=document.getElementById('s-name').value.trim();
    const h=parseFloat(document.getElementById('s-height').value);
    const w=parseFloat(document.getElementById('s-weight').value);
    if(!name){ showToastMsg('请输入名字'); return; }
    if(!h||!w){ showToastMsg('请输入身高和体重'); return; }
  }
  document.querySelectorAll('.setup-step').forEach(s=>s.classList.remove('active'));
  document.getElementById('step-'+n).classList.add('active');
  document.querySelectorAll('.pdot').forEach((d,i)=>{
    d.classList.toggle('active',i===n);
  });
}

function finishSetup(){
  profile.name=document.getElementById('s-name').value.trim()||'训练者';
  profile.height=parseFloat(document.getElementById('s-height').value)||0;
  profile.weight=parseFloat(document.getElementById('s-weight').value)||0;
  const gw=parseFloat(document.getElementById('s-goal-weight').value);
  profile.goalWeight=gw||null;
  profile.goals=setupGoals;
  profile.level=document.getElementById('s-level').value;
  profile.daysPerWeek=setupDaysPerWeek||3;
  profile.trainDays=[...setupTrainDays].sort((a,b)=>a-b);
  if(!profile.theme) profile.theme='dark';
  if(!profile.accent){ profile.accent='#F4845F'; profile.accent2='#C87FE0'; }
  profile.setup=true;
  saveProfile();
  document.getElementById('setup-overlay').style.display='none';
  document.getElementById('main-app').style.display='block';
  initApp();
}

function initApp(){
  applyTheme();
  renderHome();
}

function applyTheme(){
  document.body.className='theme-'+(profile.theme||'dark');
  if(profile.accent){
    document.documentElement.style.setProperty('--acc',profile.accent);
    document.documentElement.style.setProperty('--grad1',profile.accent);
    document.documentElement.style.setProperty('--grad2',profile.accent2||'#C87FE0');
  }
}

function getBMI(){ 
  const h=profile.height, w=profile.weight;
  if(!h||!w) return null;
  return w/(h/100)**2;
}
function getBMICat(bmi){
  if(bmi<18.5) return {cat:'偏瘦',color:'#5F9FF4'};
  if(bmi<25) return {cat:'正常',color:'#5FCC7A'};
  if(bmi<30) return {cat:'过重',color:'#F4C25F'};
  return {cat:'肥胖',color:'#F4845F'};
}
function getTargetWeight(){ 
  if(profile.goalWeight) return profile.goalWeight;
  if(!profile.height) return null;
  return Math.round(22.5*(profile.height/100)**2);
}

function renderHome(){
  document.getElementById('home-name').textContent=profile.name||'训练者';
  document.getElementById('home-date').textContent=new Date().toLocaleDateString('zh-CN',{weekday:'long',month:'long',day:'numeric'});

  const bmi=getBMI();
  const bmiCard=document.getElementById('bmi-card');
  if(bmi){
    const {cat,color}=getBMICat(bmi);
    const tgt=getTargetWeight();
    const diff=tgt?Math.round((profile.weight-tgt)*10)/10:null;
    const pct=tgt&&profile.weight>tgt?Math.min((profile.weight-tgt)/30*100,100):0;
    bmiCard.innerHTML=`
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div style="font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px">身体数据</div>
          <div style="font-size:13px;color:var(--dim);line-height:1.9">${profile.weight}kg · ${profile.height}cm</div>
          <div style="font-size:13px;color:var(--dim)">BMI <span style="color:${color};font-weight:600">${bmi.toFixed(1)}</span> · ${cat}</div>
        </div>
        ${tgt?`<div style="text-align:right">
          <div style="font-size:10px;color:var(--muted);margin-bottom:4px">${profile.goalWeight?'目标体重':'BMI正常参考'}</div>
          <div style="font-size:28px;font-weight:700;color:var(--green)">${tgt} kg</div>
          <div style="font-size:10px;color:var(--muted)">${diff>0?'还差 '+diff+'kg':'已达标 🎉'}</div>
        </div>`:''}
      </div>
      ${tgt&&diff>0?`<div style="height:4px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-top:10px"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,var(--green),var(--acc));border-radius:2px"></div></div>
      <div style="display:flex;justify-content:space-between;margin-top:4px"><span style="font-size:10px;color:var(--muted)">目标 ${tgt}kg</span><span style="font-size:10px;color:var(--acc)">现在 ${profile.weight}kg</span></div>`:''}
    `;
  } else {
    bmiCard.innerHTML='<div style="text-align:center;color:var(--muted);font-size:13px;padding:8px 0">前往设置完善身体数据</div>';
  }

  renderWeekSchedule();

  const n=profile.daysPerWeek||3;
  const days=ALL_DAYS.slice(0,n);
  const list=document.getElementById('day-list');
  list.innerHTML='';
  days.forEach(d=>{
    const done=getDoneSetsCount(d.id);
    const div=document.createElement('div');
    div.className='day-card';
    div.style.borderColor=done>0?d.color+'50':'';
    div.innerHTML=`
      <div class="day-icon" style="background:${d.color}18">
        <span class="day-icon-txt" style="color:${d.color}">Day ${d.id}</span>
      </div>
      <div class="day-info">
        <div class="day-name">${d.label}</div>
        <div class="day-sub">${d.sub} · ${d.exercises.length} 个动作</div>
      </div>
      ${done>0?`<div class="day-done-badge" style="color:${d.color}">${done} ✓</div>`:''}
      <div class="day-arr">›</div>
    `;
    div.onclick=()=>openDay(d.id);
    list.appendChild(div);
  });
}

function getDoneSetsCount(dayId){
  const dl=getDayLog(dayId);
  const day=ALL_DAYS.find(d=>d.id===dayId);
  return day.exercises.filter(ex=>dl[ex.id]?.sets?.some(s=>s.done)).length;
}

function renderWeekSchedule(){
  const trainDays=profile.trainDays||[0,2,4];
  const n=profile.daysPerWeek||3;
  const days=ALL_DAYS.slice(0,n);
  const today=todayDOW();
  const sorted=[...trainDays].sort((a,b)=>a-b);

  let html=`<div class="rec-header">
    <div class="rec-title">本周安排</div>
    <div class="rec-today">${DOW_FULL[today]}</div>
  </div>
  <div class="rec-day-row">`;

  for(let i=0;i<7;i++){
    const trainIdx=sorted.indexOf(i);
    const isTraining=trainIdx!==-1;
    const day=isTraining?days[trainIdx]:null;
    const isToday=i===today;
    html+=`<div class="rec-day-pill${isToday?' today':''}${!isTraining?' rest':''}" ${isTraining?`onclick="openDay('${day.id}')"`:''}">
      <div class="rdp-dow">周${DOW[i]}</div>
      <div class="rdp-day" style="${isTraining&&day?'color:'+day.color:''}">${isTraining&&day?'Day '+day.id:'—'}</div>
      <div class="rdp-tag">${isTraining&&day?day.label:'休息'}</div>
    </div>`;
  }
  html+='</div>';
  document.getElementById('week-schedule').innerHTML=html;
}

function openDay(dayId){
  currentDay=dayId;
  const day=ALL_DAYS.find(d=>d.id===dayId);
  document.documentElement.style.setProperty('--day-color',day.color);
  const navDay=document.getElementById('nav-day');
  navDay.style.display='';
  navDay.innerHTML=`<span class="ico">💪</span>Day ${dayId}`;

  const hdr=document.getElementById('day-hdr-content');
  hdr.style.background=`linear-gradient(180deg,${day.color}14 0%,var(--bg) 100%)`;
  hdr.innerHTML=`
    <button class="back-btn" onclick="showPage('home')">← 返回</button>
    <div class="day-hdr-tag" style="color:${day.color}">Day ${day.id} · ${day.label}</div>
    <div class="day-hdr-title">${day.sub}</div>
    <div class="day-hdr-sub">${new Date().toLocaleDateString('zh-CN')} · ${day.exercises.length} 个动作</div>
    <div style="margin-top:10px;font-size:12px;color:var(--muted);background:var(--bg2);border-radius:8px;padding:8px 12px;border-left:2px solid ${day.color}50">🔥 热身：${day.warmup}</div>
  `;
  document.getElementById('workout-hint').style.borderLeftColor=day.color;
  renderExercises(dayId);
  showPage('day');
}

function renderExercises(dayId){
  const day=ALL_DAYS.find(d=>d.id===dayId);
  const dl=getDayLog(dayId);
  const list=document.getElementById('ex-list');
  list.innerHTML='';
  day.exercises.forEach(ex=>{
    if(!dl[ex.id]) dl[ex.id]={sets:[]};
    const sets=dl[ex.id].sets;
    const done=sets.filter(s=>s.done).length;
    const allDone=sets.length>0&&done===sets.length;
    const card=document.createElement('div');
    card.className='ex-card'+(allDone?' done-all':'');
    card.style.setProperty('--done-color',day.color);
    card.id='ex-card-'+ex.id;
    card.innerHTML=`
      <div class="ex-header" onclick="toggleEx('${ex.id}')">
        <div class="ex-dot${allDone?' done':''}" id="dot-${ex.id}" style="--done-color:${day.color}"></div>
        <div class="ex-info">
          <div class="ex-name">${ex.name}</div>
          <div class="ex-meta" id="meta-${ex.id}">
            <span style="color:${day.color}CC">${ex.target}</span> · 休息 ${ex.rest}
            ${done>0?`<span style="color:var(--green)"> · ${done}/${sets.length}组完成</span>`:''}
          </div>
        </div>
        <div class="ex-chev" id="chev-${ex.id}">⌄</div>
      </div>
      <div class="ex-body" id="body-${ex.id}">
        <div id="sets-${ex.id}"></div>
        <button class="add-set-btn" style="border-color:${day.color};color:${day.color}" onclick="addSet('${dayId}','${ex.id}')">+ 加一组</button>
        <div style="margin-top:10px">
          <button class="alts-toggle" id="alts-btn-${ex.id}" onclick="toggleAlts('${ex.id}')">▼ 替代动作</button>
          <div class="alts-box" id="alts-${ex.id}" style="display:none">
            <div class="alts-title">可以换成</div>
            ${ex.alts.map(a=>`<div class="alt-item">→ ${a}</div>`).join('')}
          </div>
        </div>
      </div>`;
    list.appendChild(card);
    renderSets(dayId,ex.id);
  });
}

function renderSets(dayId,exId){
  const dl=getDayLog(dayId);
  const sets=dl[exId]?.sets||[];
  const c=document.getElementById('sets-'+exId);
  if(!c) return;
  c.innerHTML='';
  sets.forEach((s,i)=>{
    const row=document.createElement('div');
    row.className='set-row';
    row.innerHTML=`
      <div class="set-num">${i+1}</div>
      <input class="set-input" type="number" inputmode="decimal" placeholder="kg" value="${s.kg||''}" onchange="updateSet('${dayId}','${exId}',${i},'kg',this.value)">
      <span class="set-x">×</span>
      <input class="set-input" type="number" inputmode="numeric" placeholder="次" value="${s.reps||''}" onchange="updateSet('${dayId}','${exId}',${i},'reps',this.value)">
      <button class="set-done-btn${s.done?' done':''}" onclick="toggleDone('${dayId}','${exId}',${i})">${s.done?'✓ 完成':'完成'}</button>
      <button class="set-del" onclick="delSet('${dayId}','${exId}',${i})">×</button>`;
    c.appendChild(row);
  });
}

function toggleEx(exId){
  const b=document.getElementById('body-'+exId);
  const ch=document.getElementById('chev-'+exId);
  const o=b.classList.toggle('open');
  ch.classList.toggle('open',o);
}
function toggleAlts(exId){
  const box=document.getElementById('alts-'+exId);
  const btn=document.getElementById('alts-btn-'+exId);
  const show=box.style.display==='none';
  box.style.display=show?'block':'none';
  btn.textContent=(show?'▲':'▼')+' 替代动作';
}

function addSet(dayId,exId){
  const dl=getDayLog(dayId);
  if(!dl[exId]) dl[exId]={sets:[]};
  const last=dl[exId].sets[dl[exId].sets.length-1];
  dl[exId].sets.push({kg:last?.kg||'',reps:last?.reps||'',done:false});
  saveLogs(); renderSets(dayId,exId); refreshCard(dayId,exId);
}
function updateSet(dayId,exId,idx,field,val){
  const dl=getDayLog(dayId);
  dl[exId].sets[idx][field]=val; saveLogs();
}
function toggleDone(dayId,exId,idx){
  const dl=getDayLog(dayId);
  dl[exId].sets[idx].done=!dl[exId].sets[idx].done;
  saveLogs(); renderSets(dayId,exId); refreshCard(dayId,exId);
}
function delSet(dayId,exId,idx){
  const dl=getDayLog(dayId);
  dl[exId].sets.splice(idx,1);
  saveLogs(); renderSets(dayId,exId); refreshCard(dayId,exId);
}

function refreshCard(dayId,exId){
  const day=ALL_DAYS.find(d=>d.id===dayId);
  const dl=getDayLog(dayId);
  const sets=dl[exId]?.sets||[];
  const done=sets.filter(s=>s.done).length;
  const allDone=sets.length>0&&done===sets.length;
  const card=document.getElementById('ex-card-'+exId);
  const dot=document.getElementById('dot-'+exId);
  const meta=document.getElementById('meta-'+exId);
  if(!card) return;
  card.className='ex-card'+(allDone?' done-all':'');
  if(dot){ dot.className='ex-dot'+(allDone?' done':''); }
  const ex=ALL_DAYS.flatMap(d=>d.exercises).find(e=>e.id===exId);
  if(meta&&ex) meta.innerHTML=`<span style="color:${day.color}CC">${ex.target}</span> · 休息 ${ex.rest}${done>0?`<span style="color:var(--green)"> · ${done}/${sets.length}组完成</span>`:''}`;
}

function renderSettings(){
  const bmi=getBMI();
  const tgt=getTargetWeight();
  const content=document.getElementById('settings-content');
  content.innerHTML=`
    <div class="settings-section">
      <div class="settings-label">个人资料</div>
      <div class="settings-card">
        <div class="settings-row">
          <span class="settings-row-label">名字</span>
          <input class="settings-input-inline" type="text" value="${profile.name||''}" onchange="updateProfile('name',this.value)" maxlength="20">
        </div>
        <div class="settings-row">
          <span class="settings-row-label">身高</span>
          <div style="display:flex;align-items:center;gap:4px">
            <input class="settings-input-inline" type="number" inputmode="decimal" value="${profile.height||''}" onchange="updateProfile('height',parseFloat(this.value));renderBMIInline()" style="width:60px">
            <span style="font-size:12px;color:var(--muted)">cm</span>
          </div>
        </div>
        <div class="settings-row">
          <span class="settings-row-label">体重</span>
          <div style="display:flex;align-items:center;gap:4px">
            <input class="settings-input-inline" type="number" inputmode="decimal" value="${profile.weight||''}" onchange="updateProfile('weight',parseFloat(this.value));renderBMIInline()" style="width:60px">
            <span style="font-size:12px;color:var(--muted)">kg</span>
          </div>
        </div>
        <div class="settings-row">
          <span class="settings-row-label">目标体重</span>
          <div style="display:flex;align-items:center;gap:4px">
            <input class="settings-input-inline" type="number" inputmode="decimal" value="${profile.goalWeight||''}" placeholder="可选" onchange="updateProfile('goalWeight',parseFloat(this.value)||null)" style="width:60px">
            <span style="font-size:12px;color:var(--muted)">kg</span>
          </div>
        </div>
        ${bmi?`<div class="settings-row" style="flex-direction:column;align-items:flex-start;gap:4px">
          <span class="settings-row-label">BMI</span>
          <div id="bmi-inline-display" style="font-size:13px;color:var(--muted)">计算中...</div>
        </div>`:''}
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-label">训练安排</div>
      <div class="settings-card">
        <div class="settings-row">
          <span class="settings-row-label">每周训练天数</span>
          <span class="settings-row-val">${profile.daysPerWeek||3} 天</span>
        </div>
        <div class="settings-row" style="flex-direction:column;align-items:flex-start;gap:8px">
          <span class="settings-row-label">训练日</span>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            ${DOW.map((d,i)=>{
              const isTrain=(profile.trainDays||[]).includes(i);
              const day=isTrain?ALL_DAYS[((profile.trainDays||[]).sort((a,b)=>a-b).indexOf(i))]:null;
              return `<div style="min-width:36px;text-align:center;border-radius:8px;padding:6px 4px;background:${isTrain&&day?day.color+'18':'var(--bg3)'};border:1px solid ${isTrain&&day?day.color+'40':'transparent'}">
                <div style="font-size:9px;color:var(--muted)">周${d}</div>
                <div style="font-size:10px;font-weight:600;color:${isTrain&&day?day.color:'var(--muted)'}">${isTrain&&day?'Day '+day.id:'休'}</div>
              </div>`;
            }).join('')}
          </div>
        </div>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-label">主题</div>
      <div class="settings-card">
        <div class="theme-mini-grid">
          ${[['dark','#141420','🌑 深黑'],['midnight','#0D1020','🌌 午夜'],['forest','#101A12','🌲 森林'],['warm','#201610','🔥 暖棕'],['light','#F5F2EE','☀️ 浅色']].map(([name,bg,label])=>
            `<div onclick="changeTheme('${name}')" class="theme-mini${profile.theme===name?' sel':''}" style="background:${bg};display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2px">
              <span style="font-size:16px">${label.split(' ')[0]}</span>
              <span style="font-size:9px;color:${name==='light'?'#666':'#888'}">${label.split(' ')[1]}</span>
            </div>`
          ).join('')}
        </div>
        <div style="padding:4px 16px 14px">
          <div style="font-size:11px;color:var(--muted);margin-bottom:8px">强调色</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            ${[['#F4845F','#C87FE0'],['#5F9FF4','#7FD4E0'],['#5FCC7A','#A8E063'],['#F4C25F','#F47F5F'],['#E05090','#C87FE0']].map(([c1,c2])=>
              `<div onclick="changeAccent('${c1}','${c2}')" style="width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,${c1},${c2});border:2px solid ${profile.accent===c1?'var(--text)':'transparent'};cursor:pointer"></div>`
            ).join('')}
          </div>
        </div>
      </div>
    </div>

    <div style="padding:0 16px 8px">
      <button onclick="if(confirm('确定要重置所有训练记录？')){logs={};localStorage.removeItem('gym_logs');showToastMsg('已清除记录')}" style="width:100%;padding:14px;border-radius:14px;border:1px solid #3A1A1A;background:#1A0A0A;color:#884444;cursor:pointer;font-size:14px">🗑 清除所有训练记录</button>
    </div>
    <div style="padding:0 16px 8px;margin-top:8px">
      <button onclick="if(confirm('确定要重新设置？所有数据将清除')){localStorage.clear();location.reload()}" style="width:100%;padding:14px;border-radius:14px;border:1px solid var(--border);background:var(--bg2);color:var(--muted);cursor:pointer;font-size:14px">↩ 重新设置</button>
    </div>
  `;
  renderBMIInline();
}

function renderBMIInline(){
  const el=document.getElementById('bmi-inline-display');
  if(!el) return;
  const bmi=getBMI();
  if(!bmi){ el.textContent='请输入身高体重'; return; }
  const {cat,color}=getBMICat(bmi);
  el.innerHTML=`<span style="color:${color};font-weight:600">${bmi.toFixed(1)}</span> · ${cat}`;
}

function updateProfile(key,val){
  profile[key]=val;
  saveProfile();
  renderBMIInline();
}

function changeTheme(name){
  profile.theme=name;
  saveProfile();
  applyTheme();
  renderSettings();
}

function changeAccent(c1,c2){
  profile.accent=c1; profile.accent2=c2;
  saveProfile();
  applyTheme();
  renderSettings();
}

function renderHistory(){
  const cont=document.getElementById('hist-content');
  const dates=Object.keys(logs).sort((a,b)=>b.localeCompare(a)).slice(0,20);
  if(!dates.length){ cont.innerHTML='<div class="empty-state">还没有记录<br>出发去训练吧 💪</div>'; return; }
  cont.innerHTML='';
  dates.forEach(date=>{
    const dayLogs=logs[date];
    const activeDays=ALL_DAYS.filter(d=>dayLogs[d.id]&&Object.values(dayLogs[d.id]).some(ex=>ex.sets?.some(s=>s.kg||s.reps)));
    if(!activeDays.length) return;
    const block=document.createElement('div');
    block.className='hist-date';
    block.innerHTML=`<div class="hist-date-label">${date}</div>`;
    activeDays.forEach(d=>{
      const db=document.createElement('div');
      db.style.marginBottom='8px';
      db.innerHTML=`<div style="font-size:11px;color:${d.color};margin-bottom:4px">Day ${d.id} · ${d.label}</div>`;
      d.exercises.forEach(ex=>{
        const sets=(dayLogs[d.id]?.[ex.id]?.sets||[]).filter(s=>s.kg||s.reps);
        if(!sets.length) return;
        const div=document.createElement('div');
        div.className='hist-ex';
        div.innerHTML=`<div class="hist-ex-name">${ex.name}</div>
          <div class="hist-sets">${sets.map(s=>`<span class="hist-set-tag ${s.done?'hist-done':'hist-undone'}">${s.kg?s.kg+'kg':'—'}×${s.reps||'—'}${s.done?' ✓':''}</span>`).join('')}</div>`;
        db.appendChild(div);
      });
      block.appendChild(db);
    });
    cont.appendChild(block);
  });
}

function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  const nb=document.getElementById('nav-'+name);
  if(nb) nb.classList.add('active');
  if(name==='history') renderHistory();
  if(name==='home') renderHome();
}

function hideSplash(){
  const s=document.getElementById('splash');
  s.classList.add('hide');
  setTimeout(()=>s.remove(),350);
}
loadData();
if(profile.setup){
  document.getElementById('setup-overlay').style.display='none';
  document.getElementById('main-app').style.display='block';
  
  applyTheme();
  
  requestAnimationFrame(()=>{
    initApp();
    requestAnimationFrame(hideSplash);
  });
} else {
  requestAnimationFrame(hideSplash);
}
</script>
</body>
