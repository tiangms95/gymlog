round:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--muted);flex-shrink:0}.set-input{width:62px;background:var(--bg3);border:1px solid #2A2A38;border-radius:9px;padding:8px 6px;color:var(--text);font-size:15px;text-align:center;-webkit-appearance:none}.set-input:focus{outline:none}.set-x{color:#444;font-size:13px}.set-done-btn{flex:1;padding:8px;border-radius:9px;border:none;background:var(--bg3);color:var(--muted);cursor:pointer;font-size:12px;transition:all .2s}.set-done-btn.done{background:#1A2A1A;color:var(--green)}.set-del{width:32px;height:32px;border-radius:8px;border:none;background:var(--bg3);color:#444;cursor:pointer;font-size:16px;flex-shrink:0}.add-set-btn{width:100%;padding:9px;border-radius:9px;border:1px dashed;background:transparent;cursor:pointer;font-size:13px;margin-top:2px;opacity:.7}.alts-toggle{font-size:11px;color:var(--muted);background:none;border:none;cursor:pointer;padding:8px 0 0}.alts-box{background:#0C0C14;border-radius:10px;padding:10px 14px;margin-top:8px}.alts-title{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px}.alt-item{font-size:12px;color:var(--dim);padding:4px 0;border-bottom:1px solid #1A1A24}.alt-item:last-child{border-bottom:none}.settings-section{margin:0 16px 20px}.settings-label{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}.settings-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden}.settings-row{padding:14px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}.settings-row:last-child{border-bottom:none}.settings-row-label{font-size:14px;color:var(--text)}.settings-row-val{font-size:13px;color:var(--muted)}.settings-input-inline{background:transparent;border:none;color:var(--text);font-size:14px;text-align:right;width:80px;-webkit-appearance:none}.settings-input-inline:focus{outline:none;color:var(--acc)}.hist-date{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:16px;margin:0 16px 12px}.hist-date-label{font-size:13px;color:var(--dim);font-weight:600;margin-bottom:10px}.hist-ex{background:var(--bg3);border-radius:8px;padding:8px 12px;margin-bottom:4px}.hist-ex-name{font-size:11px;color:var(--dim);margin-bottom:4px}.hist-sets{display:flex;flex-wrap:wrap;gap:5px}.hist-set-tag{font-size:11px;border-radius:6px;padding:3px 8px}.hist-done{background:#1A2A1A;color:var(--green)}.hist-undone{background:var(--bg);color:#555}.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#1A2A1A;color:var(--green);font-size:12px;padding:8px 16px;border-radius:20px;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none}.toast.show{opacity:1}.theme-mini-grid{display:flex;gap:8px;flex-wrap:wrap;padding:12px 16px}.theme-mini{width:40px;height:40px;border-radius:10px;border:2px solid transparent;cursor:pointer;transition:all .2s}.theme-mini.sel{border-color:var(--acc);transform:scale(1.1)}.empty-state{text-align:center;color:#444;font-size:14px;margin-top:60px;line-height:2.2}</style>
